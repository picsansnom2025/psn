{% doc %}
  @prompt
    生成一个左对齐的标题
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-heading-title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size_mobile }}px;
    text-align: {{ block.settings.alignment }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    line-height: {{ block.settings.line_height }};
  }

  @media screen and (min-width: 750px) {
    .ai-heading-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_tag == 'h1' %}
    <h1 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
  {% elsif block.settings.heading_tag == 'h2' %}
    <h2 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
  {% elsif block.settings.heading_tag == 'h3' %}
    <h3 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
  {% elsif block.settings.heading_tag == 'h4' %}
    <h4 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
  {% elsif block.settings.heading_tag == 'h5' %}
    <h5 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
  {% else %}
    <h6 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
  {% endif %}
</div>

{% schema %}
{
  "name": "Left aligned heading",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Your heading here"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Font size (desktop)",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.2,
      "step": 0.1,
      "unit": "em",
      "default": 0
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Left aligned heading"
    }
  ]
}
{% endschema %}
