{% doc %}
  @prompt
    帮我增加一个有背景的联络表单
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-contact-form-wrapper-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-contact-form-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-contact-form-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-contact-form-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-contact-form-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-contact-form-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 {{ block.settings.description_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form-fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.field_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-contact-form-row-{{ ai_gen_id }}.ai-contact-form-row-two-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.label_size }}px;
    margin-bottom: 8px;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
  }

  .ai-contact-form-input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form-textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.6;
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.textarea_height }}px;
    resize: vertical;
  }

  .ai-contact-form-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form-message-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    text-align: center;
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-contact-form-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-form-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form-wrapper-{{ ai_gen_id }}">
    <div class="ai-contact-form-background-{{ ai_gen_id }}">
      {% if block.settings.background_image %}
        <img
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
        >
      {% else %}
        <div class="ai-contact-form-background-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-contact-form-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-contact-form-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-form-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-contact-form-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="ai-contact-form-message-{{ ai_gen_id }} ai-contact-form-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="ai-contact-form-message-{{ ai_gen_id }} ai-contact-form-error-{{ ai_gen_id }}">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="ai-contact-form-fields-{{ ai_gen_id }}">
          <div class="ai-contact-form-row-{{ ai_gen_id }} ai-contact-form-row-two-{{ ai_gen_id }}">
            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              {% if block.settings.show_labels %}
                <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
                  {{ block.settings.name_label }}
                </label>
              {% endif %}
              <input
                type="text"
                id="contact-name-{{ ai_gen_id }}"
                name="contact[name]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                placeholder="{{ block.settings.name_placeholder }}"
                {% if block.settings.name_required %}required{% endif %}
              >
            </div>

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              {% if block.settings.show_labels %}
                <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
                  {{ block.settings.email_label }}
                </label>
              {% endif %}
              <input
                type="email"
                id="contact-email-{{ ai_gen_id }}"
                name="contact[email]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                placeholder="{{ block.settings.email_placeholder }}"
                autocomplete="email"
                required
              >
            </div>
          </div>

          {% if block.settings.show_phone %}
            <div class="ai-contact-form-row-{{ ai_gen_id }}">
              <div class="ai-contact-form-field-{{ ai_gen_id }}">
                {% if block.settings.show_labels %}
                  <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
                    {{ block.settings.phone_label }}
                  </label>
                {% endif %}
                <input
                  type="tel"
                  id="contact-phone-{{ ai_gen_id }}"
                  name="contact[phone]"
                  class="ai-contact-form-input-{{ ai_gen_id }}"
                  placeholder="{{ block.settings.phone_placeholder }}"
                  autocomplete="tel"
                  {% if block.settings.phone_required %}required{% endif %}
                >
              </div>
            </div>
          {% endif %}

          <div class="ai-contact-form-row-{{ ai_gen_id }}">
            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              {% if block.settings.show_labels %}
                <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
                  {{ block.settings.message_label }}
                </label>
              {% endif %}
              <textarea
                id="contact-message-{{ ai_gen_id }}"
                name="contact[body]"
                class="ai-contact-form-textarea-{{ ai_gen_id }}"
                placeholder="{{ block.settings.message_placeholder }}"
                required
              ></textarea>
            </div>
          </div>
        </div>

        <div class="ai-contact-form-button-wrapper-{{ ai_gen_id }}">
          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const requiredFields = this.form.querySelectorAll('[required]');
        let isValid = true;

        requiredFields.forEach(field => {
          if (!field.value.trim()) {
            isValid = false;
            field.style.borderColor = '#D82C0D';
          } else {
            field.style.borderColor = '';
          }
        });

        if (!isValid) {
          event.preventDefault();
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

