{% doc %}
  @prompt
    帮我生成一个图片轮播卡片底下还有字, 单行轮播,八个卡片，文字不能再卡片上
    文字在卡片的左下角, 一行八个卡片，大小不变，可以往左边滑动
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fixed-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
  }

  .ai-fixed-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-fixed-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
    cursor: grab;
  }

  .ai-fixed-carousel-track-{{ ai_gen_id }}:active {
    cursor: grabbing;
  }

  .ai-fixed-carousel-card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    position: relative;
  }

  .ai-fixed-carousel-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_height }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-fixed-carousel-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-fixed-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-fixed-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    max-width: 150px;
    max-height: 150px;
  }

  .ai-fixed-carousel-text-{{ ai_gen_id }} {
    margin-top: {{ block.settings.text_spacing }}px;
  }

  .ai-fixed-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_bottom_spacing }}px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-fixed-carousel-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: calc({{ block.settings.card_height }}px / 2);
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-fixed-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media screen and (max-width: 989px) {
    .ai-fixed-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_tablet }}px;
    }

    .ai-fixed-carousel-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.card_height_tablet }}px;
    }

    .ai-fixed-carousel-nav-{{ ai_gen_id }} {
      top: calc({{ block.settings.card_height_tablet }}px / 2);
    }

    .ai-fixed-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }

    .ai-fixed-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-fixed-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
    }

    .ai-fixed-carousel-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.card_height_mobile }}px;
    }

    .ai-fixed-carousel-nav-{{ ai_gen_id }} {
      top: calc({{ block.settings.card_height_mobile }}px / 2);
      width: calc({{ block.settings.nav_button_size }}px * 0.8);
      height: calc({{ block.settings.nav_button_size }}px * 0.8);
    }

    .ai-fixed-carousel-nav-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-fixed-carousel-nav-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-fixed-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-fixed-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.85);
    }
  }
{% endstyle %}

<fixed-card-carousel-{{ ai_gen_id }} class="ai-fixed-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fixed-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-fixed-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign description_key = 'card_' | append: i | append: '_description'
          
          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_description = block.settings[description_key]
        %}
        
        <div class="ai-fixed-carousel-card-{{ ai_gen_id }}">
          <div class="ai-fixed-carousel-image-wrapper-{{ ai_gen_id }}">
            {% if card_image != blank %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
              >
            {% else %}
              <div class="ai-fixed-carousel-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if card_title != blank or card_description != blank %}
            <div class="ai-fixed-carousel-text-{{ ai_gen_id }}">
              {% if card_title != blank %}
                <h3 class="ai-fixed-carousel-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}
              {% if card_description != blank %}
                <p class="ai-fixed-carousel-description-{{ ai_gen_id }}">{{ card_description }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <button
      class="ai-fixed-carousel-nav-{{ ai_gen_id }} ai-fixed-carousel-nav-{{ ai_gen_id }}--prev"
      aria-label="Previous"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-fixed-carousel-nav-{{ ai_gen_id }} ai-fixed-carousel-nav-{{ ai_gen_id }}--next"
      aria-label="Next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</fixed-card-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class FixedCardCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPosition = 0;
        this.isDragging = false;
        this.startX = 0;
        this.scrollLeft = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-fixed-carousel-track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-fixed-carousel-card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-fixed-carousel-nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-fixed-carousel-nav-{{ ai_gen_id }}--next');
        this.wrapper = this.querySelector('.ai-fixed-carousel-wrapper-{{ ai_gen_id }}');

        this.updateCardWidth();
        this.setupEventListeners();
        this.updateButtons();

        window.addEventListener('resize', () => {
          this.updateCardWidth();
          this.updateCarousel();
        });
      }

      updateCardWidth() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardWidth = {{ block.settings.card_width_mobile }};
        } else if (width <= 989) {
          this.cardWidth = {{ block.settings.card_width_tablet }};
        } else {
          this.cardWidth = {{ block.settings.card_width }};
        }
        this.gap = {{ block.settings.card_gap }};
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.goToPrev());
        this.nextButton.addEventListener('click', () => this.goToNext());

        this.track.addEventListener('mousedown', (e) => this.startDragging(e));
        this.track.addEventListener('mousemove', (e) => this.onDragging(e));
        this.track.addEventListener('mouseup', () => this.stopDragging());
        this.track.addEventListener('mouseleave', () => this.stopDragging());

        this.track.addEventListener('touchstart', (e) => this.startDragging(e));
        this.track.addEventListener('touchmove', (e) => this.onDragging(e));
        this.track.addEventListener('touchend', () => this.stopDragging());
      }

      startDragging(e) {
        this.isDragging = true;
        this.startX = e.type.includes('mouse') ? e.pageX : e.touches[0].pageX;
        this.scrollLeft = this.currentPosition;
        this.track.style.transition = 'none';
      }

      onDragging(e) {
        if (!this.isDragging) return;
        e.preventDefault();
        const x = e.type.includes('mouse') ? e.pageX : e.touches[0].pageX;
        const walk = (x - this.startX);
        this.currentPosition = this.scrollLeft + walk;
        
        const maxScroll = this.getMaxScroll();
        this.currentPosition = Math.max(Math.min(this.currentPosition, 0), -maxScroll);
        
        this.track.style.transform = `translateX(${this.currentPosition}px)`;
      }

      stopDragging() {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.track.style.transition = 'transform 0.5s ease';
        this.updateButtons();
      }

      goToNext() {
        const maxScroll = this.getMaxScroll();
        this.currentPosition -= (this.cardWidth + this.gap);
        this.currentPosition = Math.max(this.currentPosition, -maxScroll);
        this.updateCarousel();
      }

      goToPrev() {
        this.currentPosition += (this.cardWidth + this.gap);
        this.currentPosition = Math.min(this.currentPosition, 0);
        this.updateCarousel();
      }

      getMaxScroll() {
        const totalWidth = (this.cardWidth + this.gap) * this.cards.length - this.gap;
        const containerWidth = this.wrapper.offsetWidth;
        return Math.max(0, totalWidth - containerWidth);
      }

      updateCarousel() {
        this.track.style.transform = `translateX(${this.currentPosition}px)`;
        this.updateButtons();
      }

      updateButtons() {
        const maxScroll = this.getMaxScroll();
        this.prevButton.disabled = this.currentPosition >= 0;
        this.nextButton.disabled = this.currentPosition <= -maxScroll;
      }
    }

    customElements.define('fixed-card-carousel-{{ ai_gen_id }}', FixedCardCarousel{{ ai_gen_id }});
  })();
</script>

