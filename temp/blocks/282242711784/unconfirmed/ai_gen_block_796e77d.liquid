{% doc %}
  @prompt
    轮播卡片
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-cards-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: block;
  }

  .ai-carousel-cards__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 24px;
  }

  .ai-carousel-cards__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
  }

  .ai-carousel-cards__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-carousel-cards__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-carousel-cards__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .ai-carousel-cards__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap }}px * ({{ block.settings.cards_per_view_mobile | minus: 1 }})) / {{ block.settings.cards_per_view_mobile }});
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-carousel-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-carousel-cards__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_image_height }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-carousel-cards__card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-cards__card-image-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-cards__card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-carousel-cards__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-carousel-cards__card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-carousel-cards__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  .ai-carousel-cards__button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_icon_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-carousel-cards__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    transform: scale(1.1);
  }

  .ai-carousel-cards__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-cards__button-{{ ai_gen_id }}:disabled:hover {
    transform: scale(1);
  }

  .ai-carousel-cards__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-carousel-cards__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-carousel-cards__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-cards__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (min-width: 750px) {
    .ai-carousel-cards__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px * ({{ block.settings.cards_per_view_tablet | minus: 1 }})) / {{ block.settings.cards_per_view_tablet }});
    }
  }

  @media screen and (min-width: 990px) {
    .ai-carousel-cards__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px * ({{ block.settings.cards_per_view_desktop | minus: 1 }})) / {{ block.settings.cards_per_view_desktop }});
    }
  }
{% endstyle %}

<carousel-cards-{{ ai_gen_id }} class="ai-carousel-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subtitle != blank %}
    <div class="ai-carousel-cards__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-carousel-cards__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-carousel-cards__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-carousel-cards__container-{{ ai_gen_id }}">
    <div class="ai-carousel-cards__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign text_key = 'card_' | append: i | append: '_text'
          
          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_text = block.settings[text_key]
        %}
        
        <div class="ai-carousel-cards__card-{{ ai_gen_id }}">
          <div class="ai-carousel-cards__card-image-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="{{ block.settings.card_image_height }}"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
          <div class="ai-carousel-cards__card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-carousel-cards__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}
            {% if card_text != blank %}
              <p class="ai-carousel-cards__card-text-{{ ai_gen_id }}">{{ card_text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ai-carousel-cards__controls-{{ ai_gen_id }}">
    <button
      class="ai-carousel-cards__button-{{ ai_gen_id }} ai-carousel-cards__prev-{{ ai_gen_id }}"
      aria-label="上一张"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-carousel-cards__dots-{{ ai_gen_id }}"></div>

    <button
      class="ai-carousel-cards__button-{{ ai_gen_id }} ai-carousel-cards__next-{{ ai_gen_id }}"
      aria-label="下一张"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</carousel-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_view_mobile }};
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-cards__track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-carousel-cards__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-cards__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-cards__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-cards__dots-{{ ai_gen_id }}');

        this.updateCardsPerView();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width >= 990) {
          this.cardsPerView = {{ block.settings.cards_per_view_desktop }};
        } else if (width >= 750) {
          this.cardsPerView = {{ block.settings.cards_per_view_tablet }};
        } else {
          this.cardsPerView = {{ block.settings.cards_per_view_mobile }};
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const totalSlides = Math.ceil(this.cards.length / this.cardsPerView);
        
        for (let i = 0; i < totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-cards__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', '跳转到第 ' + (i + 1) + ' 页');
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.createDots();
          this.currentIndex = 0;
          this.updateCarousel();
        });

        this.addEventListener('mouseenter', () => {
          if (this.autoplay) {
            this.stopAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        const maxIndex = Math.ceil(this.cards.length / this.cardsPerView) - 1;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * this.cardsPerView * (cardWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        const maxIndex = Math.ceil(this.cards.length / this.cardsPerView) - 1;
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === maxIndex;

        const dots = this.dotsContainer.querySelectorAll('.ai-carousel-cards__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          const maxIndex = Math.ceil(this.cards.length / this.cardsPerView) - 1;
          if (this.currentIndex < maxIndex) {
            this.next();
          } else {
            this.currentIndex = 0;
            this.updateCarousel();
          }
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('carousel-cards-{{ ai_gen_id }}', CarouselCards{{ ai_gen_id }});
  })();
</script>

