{% doc %}
  @prompt
     添加自訂 Liquid
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-liquid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} h1,
  .ai-custom-liquid-content-{{ ai_gen_id }} h2,
  .ai-custom-liquid-content-{{ ai_gen_id }} h3,
  .ai-custom-liquid-content-{{ ai_gen_id }} h4,
  .ai-custom-liquid-content-{{ ai_gen_id }} h5,
  .ai-custom-liquid-content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin-top: 0;
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} table th,
  .ai-custom-liquid-content-{{ ai_gen_id }} table td {
    padding: 8px;
    border: 1px solid {{ block.settings.table_border_color }};
    text-align: left;
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} table th {
    background-color: {{ block.settings.table_header_bg }};
    font-weight: 600;
  }

  .ai-custom-liquid-placeholder-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    background-color: #f9f9f9;
    border: 2px dashed #ddd;
    border-radius: {{ block.settings.border_radius }}px;
    color: #666;
  }

  .ai-custom-liquid-placeholder-icon-{{ ai_gen_id }} {
    font-size: 48px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  .ai-custom-liquid-placeholder-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #333;
  }

  .ai-custom-liquid-placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
  }
{% endstyle %}

<div class="ai-custom-liquid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_liquid != blank %}
    <div class="ai-custom-liquid-content-{{ ai_gen_id }}">
      {{ block.settings.custom_liquid }}
    </div>
  {% else %}
    <div class="ai-custom-liquid-placeholder-{{ ai_gen_id }}">
      <div class="ai-custom-liquid-placeholder-icon-{{ ai_gen_id }}">
        &lt;/&gt;
      </div>
      <div class="ai-custom-liquid-placeholder-title-{{ ai_gen_id }}">
        Custom Liquid block
      </div>
      <div class="ai-custom-liquid-placeholder-text-{{ ai_gen_id }}">
        Add your custom Liquid code in the block settings
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom Liquid",
  "tag": null,
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Custom Liquid code"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#0066cc"
    },
    {
      "type": "header",
      "content": "Table style"
    },
    {
      "type": "color",
      "id": "table_border_color",
      "label": "Border",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "table_header_bg",
      "label": "Header background",
      "default": "#f4f4f4"
    }
  ],
  "presets": [
    {
      "name": "Custom Liquid"
    }
  ]
}
{% endschema %}
