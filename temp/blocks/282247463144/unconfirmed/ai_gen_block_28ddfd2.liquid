{% doc %}
  @prompt
    帮我生成一个卡片可以有图片和文字的，是一行多个的
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-card-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-card-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-card-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-card-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-card-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .ai-card-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-card-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-card-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-card-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-card-grid__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-card-grid__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-card-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-card-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<card-grid-{{ ai_gen_id }} class="ai-card-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-card-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'card_' | append: i | append: '_image'
        assign title_key = 'card_' | append: i | append: '_title'
        assign description_key = 'card_' | append: i | append: '_description'
        assign link_key = 'card_' | append: i | append: '_link'

        assign card_image = block.settings[image_key]
        assign card_title = block.settings[title_key]
        assign card_description = block.settings[description_key]
        assign card_link = block.settings[link_key]
      %}

      <div class="ai-card-grid__card-{{ ai_gen_id }}">
        {% if card_link != blank %}
          <a href="{{ card_link }}" style="text-decoration: none; color: inherit;">
        {% endif %}

        <div class="ai-card-grid__image-wrapper-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 600 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              width="600"
              height="600"
              class="ai-card-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-card-grid__image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="ai-card-grid__content-{{ ai_gen_id }}">
          {% if card_title != blank %}
            <h3 class="ai-card-grid__title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}
          {% if card_description != blank %}
            <p class="ai-card-grid__description-{{ ai_gen_id }}">{{ card_description }}</p>
          {% endif %}
        </div>

        {% if card_link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</card-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CardGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-card-grid__card-{{ ai_gen_id }}');
      }
    }

    customElements.define('card-grid-{{ ai_gen_id }}', CardGrid{{ ai_gen_id }});
  })();
</script>

