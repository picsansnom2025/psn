{% doc %}
  @prompt
    添加一个单行卡片
    图片3:4比例
    图片的左下角有一行文字
    一行八个卡片内容, 图片大一点
    左下角有文字
    电脑端一页4个, 卡片的左下角加一个小标题
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-card-row-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-card-row-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .ai-card-row-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .ai-card-row-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  .ai-card-row-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 3px;
  }

  .ai-card-item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 3 }}px) / 4);
    min-width: 200px;
    position: relative;
  }

  .ai-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 133.33%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_bg_color }};
  }

  .ai-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-card-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.text_padding }}px;
    left: {{ block.settings.text_padding }}px;
    right: {{ block.settings.text_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-card-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: 1.2;
    font-weight: {{ block.settings.subtitle_weight }};
    margin: 0;
  }

  .ai-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.3;
    font-weight: {{ block.settings.text_weight }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-card-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
      min-width: 180px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-card-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
      min-width: 150px;
    }
  }
{% endstyle %}

<card-row-{{ ai_gen_id }} class="ai-card-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-card-row-container-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign image_key = 'card_' | append: i | append: '_image'
        assign subtitle_key = 'card_' | append: i | append: '_subtitle'
        assign text_key = 'card_' | append: i | append: '_text'
        assign link_key = 'card_' | append: i | append: '_link'
        
        assign card_image = block.settings[image_key]
        assign card_subtitle = block.settings[subtitle_key]
        assign card_text = block.settings[text_key]
        assign card_link = block.settings[link_key]
      %}
      
      <div class="ai-card-item-{{ ai_gen_id }}">
        {% if card_link != blank %}
          <a href="{{ card_link }}" style="text-decoration: none; color: inherit;">
        {% endif %}
        
        <div class="ai-card-image-wrapper-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 600 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              class="ai-card-image-{{ ai_gen_id }}"
              width="600"
              height="800"
            >
          {% else %}
            <div class="ai-card-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          {% if card_subtitle != blank or card_text != blank %}
            <div class="ai-card-text-overlay-{{ ai_gen_id }}">
              {% if card_subtitle != blank %}
                <div class="ai-card-subtitle-{{ ai_gen_id }}">
                  {{ card_subtitle }}
                </div>
              {% endif %}
              {% if card_text != blank %}
                <div class="ai-card-title-{{ ai_gen_id }}">
                  {{ card_text }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
        
        {% if card_link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</card-row-{{ ai_gen_id }}>

<script>
  (function() {
    class CardRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-card-row-container-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.container) return;
        
        let isDown = false;
        let startX;
        let scrollLeft;

        this.container.addEventListener('mousedown', (e) => {
          isDown = true;
          this.container.style.cursor = 'grabbing';
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 2;
          this.container.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('card-row-{{ ai_gen_id }}', CardRow{{ ai_gen_id }});
  })();
</script>

