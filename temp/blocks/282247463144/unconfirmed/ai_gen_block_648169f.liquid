{% doc %}
  @prompt
    增加一个单行轮播卡片
    卡片内容是图片比例3:4
    图片左下角空白处添加一行文字
    单行卡片一行为八个卡片, 一行八个卡片内容, 图片大一点
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-carousel-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - 7 * {{ block.settings.card_gap }}px) / 8);
    min-width: 200px;
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background_color }};
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 133.33%;
    overflow: hidden;
  }

  .ai-carousel-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-carousel-text-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.text_bottom_offset }}px;
    left: {{ block.settings.text_left_offset }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    background-color: {{ block.settings.text_background_color }};
    padding: {{ block.settings.text_padding_vertical }}px {{ block.settings.text_padding_horizontal }}px;
    border-radius: {{ block.settings.text_border_radius }}px;
    max-width: calc(100% - {{ block.settings.text_left_offset | times: 2 }}px);
    word-wrap: break-word;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - 2 * {{ block.settings.card_gap }}px) / 3);
      min-width: 120px;
    }
  }
{% endstyle %}

<carousel-block-{{ ai_gen_id }} class="ai-carousel-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign image_key = 'card_image_' | append: i
        assign text_key = 'card_text_' | append: i
        assign card_image = block.settings[image_key]
        assign card_text = block.settings[text_key]
      %}
      
      <div class="ai-carousel-card-{{ ai_gen_id }}">
        <div class="ai-carousel-image-wrapper-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 800 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              class="ai-carousel-image-{{ ai_gen_id }}"
              width="800"
              height="1067"
            >
          {% else %}
            <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          {% if card_text != blank %}
            <div class="ai-carousel-text-{{ ai_gen_id }}">
              {{ card_text }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</carousel-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-carousel-wrapper-{{ ai_gen_id }}');
        this.setupTouchScroll();
      }

      setupTouchScroll() {
        if (!this.wrapper) return;
        
        let isDown = false;
        let startX;
        let scrollLeft;

        this.wrapper.addEventListener('mousedown', (e) => {
          isDown = true;
          this.wrapper.style.cursor = 'grabbing';
          startX = e.pageX - this.wrapper.offsetLeft;
          scrollLeft = this.wrapper.scrollLeft;
        });

        this.wrapper.addEventListener('mouseleave', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mouseup', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.wrapper.offsetLeft;
          const walk = (x - startX) * 2;
          this.wrapper.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('carousel-block-{{ ai_gen_id }}', CarouselBlock{{ ai_gen_id }});
  })();
</script>

