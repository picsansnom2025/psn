{% doc %}
  @prompt
    帮我生成一个图片轮播卡片底下还有字, 单行轮播,八个卡片，文字不能再卡片上
    文字在卡片的左下角
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-card-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
  }

  .ai-card-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-card-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-card-carousel-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_view | minus: 1 }}px) / {{ block.settings.cards_per_view }});
    position: relative;
  }

  .ai-card-carousel-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.card_aspect_ratio }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-card-carousel-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-card-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-card-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-card-carousel-text-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.text_offset_bottom }}px;
    left: {{ block.settings.text_offset_left }}px;
    z-index: 2;
  }

  .ai-card-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-card-carousel-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-card-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-card-carousel-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-card-carousel-nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-card-carousel-nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-card-carousel-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-card-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media screen and (max-width: 989px) {
    .ai-card-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_view_tablet | minus: 1 }}px) / {{ block.settings.cards_per_view_tablet }});
    }

    .ai-card-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }

    .ai-card-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-card-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_view_mobile | minus: 1 }}px) / {{ block.settings.cards_per_view_mobile }});
    }

    .ai-card-carousel-nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_button_size }}px * 0.8);
      height: calc({{ block.settings.nav_button_size }}px * 0.8);
    }

    .ai-card-carousel-nav-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-card-carousel-nav-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-card-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-card-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.85);
    }
  }
{% endstyle %}

<card-carousel-{{ ai_gen_id }} class="ai-card-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-card-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-card-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign description_key = 'card_' | append: i | append: '_description'
          
          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_description = block.settings[description_key]
        %}
        
        <div class="ai-card-carousel-card-{{ ai_gen_id }}">
          <div class="ai-card-carousel-image-wrapper-{{ ai_gen_id }}">
            {% if card_image != blank %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
              >
            {% else %}
              <div class="ai-card-carousel-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if card_title != blank or card_description != blank %}
            <div class="ai-card-carousel-text-{{ ai_gen_id }}">
              {% if card_title != blank %}
                <h3 class="ai-card-carousel-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}
              {% if card_description != blank %}
                <p class="ai-card-carousel-description-{{ ai_gen_id }}">{{ card_description }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <button
      class="ai-card-carousel-nav-{{ ai_gen_id }} ai-card-carousel-nav-{{ ai_gen_id }}--prev"
      aria-label="Previous"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-card-carousel-nav-{{ ai_gen_id }} ai-card-carousel-nav-{{ ai_gen_id }}--next"
      aria-label="Next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</card-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CardCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_view }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-card-carousel-track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-card-carousel-card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-card-carousel-nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-card-carousel-nav-{{ ai_gen_id }}--next');

        this.updateCardsPerView();
        this.setupEventListeners();
        this.updateButtons();

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.updateCarousel();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = {{ block.settings.cards_per_view_mobile }};
        } else if (width <= 989) {
          this.cardsPerView = {{ block.settings.cards_per_view_tablet }};
        } else {
          this.cardsPerView = {{ block.settings.cards_per_view }};
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.goToPrev());
        this.nextButton.addEventListener('click', () => this.goToNext());
      }

      goToNext() {
        const maxIndex = this.cards.length - this.cardsPerView;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      goToPrev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        const maxIndex = this.cards.length - this.cardsPerView;
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('card-carousel-{{ ai_gen_id }}', CardCarousel{{ ai_gen_id }});
  })();
</script>

