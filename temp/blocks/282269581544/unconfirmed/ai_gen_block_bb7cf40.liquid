{% doc %}
  @prompt
    帮我生成一个图片轮播卡片底下还有字
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
  }

  .ai-carousel-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    flex-shrink: 0;
  }

  .ai-carousel-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-carousel-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-carousel-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-carousel-nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-carousel-nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-carousel-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ block.settings.dots_spacing }}px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-carousel-caption-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-top: {{ block.settings.caption_spacing }}px;
    padding: 0 {{ block.settings.caption_padding }}px;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_bottom_spacing }}px;
    font-weight: 600;
  }

  .ai-carousel-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_button_size }}px * 0.8);
      height: calc({{ block.settings.nav_button_size }}px * 0.8);
    }

    .ai-carousel-nav-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-carousel-nav-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-container-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% liquid
        assign has_images = false
        for i in (1..5)
          assign image_key = 'image_' | append: i
          if block.settings[image_key] != blank
            assign has_images = true
            break
          endif
        endfor
      %}

      {% if has_images %}
        {% for i in (1..5) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}">
              <img
                src="{{ image | image_url: width: 2000 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-carousel-slide-{{ ai_gen_id }}">
          <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-carousel-empty-state-{{ ai_gen_id }}">
              Next, add images to the carousel
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_images %}
      <button
        class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}
  </div>

  {% if has_images %}
    <div class="ai-carousel-dots-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          <button
            class="ai-carousel-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-slide="{{ forloop.index | minus: 1 }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="ai-carousel-caption-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h3 class="ai-carousel-title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
    {% endif %}
    {% if block.settings.description != blank %}
      <div class="ai-carousel-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}
  </div>
</image-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-carousel-nav-{{ ai_gen_id }}--next');
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');

        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateCarousel();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateCarousel();
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateCarousel();
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
  })();
</script>

