{% doc %}
  @prompt
    帮我增加一个有背景的联络表单
    可以调节背景透明度的表单
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-contact-form-wrapper-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-contact-form-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-contact-form-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-contact-form-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-contact-form-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-contact-form-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-contact-form-header-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 12px;
  }

  .ai-contact-form-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
  }

  .ai-contact-form-fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form-row-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 8px;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
  }

  .ai-contact-form-input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form-textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.6;
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 16px;
    font-size: 14px;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-row-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-contact-form-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-contact-form-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }}
  class="ai-contact-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-contact-form-wrapper-{{ ai_gen_id }}">
    <div class="ai-contact-form-background-{{ ai_gen_id }}">
      {% if block.settings.background_image %}
        <img
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
        >
      {% else %}
        <div class="ai-contact-form-background-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-contact-form-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-contact-form-content-{{ ai_gen_id }}">
      {%- form 'contact' -%}
        {% if block.settings.title != blank or block.settings.description != blank %}
          <div class="ai-contact-form-header-{{ ai_gen_id }}">
            {% if block.settings.title != blank %}
              <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
            {% endif %}
            {% if block.settings.description != blank %}
              <div class="ai-contact-form-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-contact-form-fields-{{ ai_gen_id }}">
          <div class="ai-contact-form-row-{{ ai_gen_id }}">
            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
                {{ block.settings.name_label }}
              </label>
              <input
                type="text"
                id="contact-name-{{ ai_gen_id }}"
                name="contact[name]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                value="{{ form.name }}"
                placeholder="{{ block.settings.name_placeholder }}"
                required
              >
            </div>

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
                {{ block.settings.email_label }}
              </label>
              <input
                type="email"
                id="contact-email-{{ ai_gen_id }}"
                name="contact[email]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                value="{{ form.email }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="contact-form-error-{{ ai_gen_id }}"
                {% endif %}
                {% if form.posted_successfully? %}
                  aria-describedby="contact-form-success-{{ ai_gen_id }}"
                {% endif %}
                placeholder="{{ block.settings.email_placeholder }}"
                required
              >
            </div>
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
              {{ block.settings.phone_label }}
            </label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              value="{{ form.phone }}"
              placeholder="{{ block.settings.phone_placeholder }}"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
              {{ block.settings.message_label }}
            </label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-form-textarea-{{ ai_gen_id }}"
              placeholder="{{ block.settings.message_placeholder }}"
              required
            >{{ form.body }}</textarea>
          </div>

          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>

          {%- if form.errors -%}
            <div
              id="contact-form-error-{{ ai_gen_id }}"
              class="ai-contact-form-error-{{ ai_gen_id }}"
            >
              <span>{{ form.errors.messages.email }}</span>
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div
              id="contact-form-success-{{ ai_gen_id }}"
              class="ai-contact-form-success-{{ ai_gen_id }}"
            >
              <span>{{ block.settings.success_message }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endform -%}
    </div>
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && form.querySelector('.ai-contact-form-success-{{ ai_gen_id }}')) {
          form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

